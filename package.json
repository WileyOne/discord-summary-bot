{
  "name": "discord-summary-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "register-commands": "node dist/scripts/register-commands.js",
    "compose:up": "docker compose up -d --build",
    "compose:up:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f --tail=200 bot"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
