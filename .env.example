# Discord — create an application + bot at https://discord.com/developers/applications
# Required intents in the portal: Message Content Intent (for reading message bodies)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Comma-separated numeric channel IDs whose messages should be collected and summarized
TRACKED_CHANNELS=

# Channel where daily / on-demand summaries are posted (numeric channel ID)
SUMMARY_CHANNEL_ID=

# Cron expression (server timezone follows TZ below). Example: 18:00 Mon–Fri UTC
SUMMARY_CRON=0 18 * * 1-5

# Optional: IANA timezone for interpreting SUMMARY_CRON and calendar-day boundaries (default UTC)
TZ=UTC

# Ollama HTTP API (Docker Compose default reaches the sibling service by name)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# SQLite path (mounted volume in Docker Compose)
DB_PATH=/data/bot.db
