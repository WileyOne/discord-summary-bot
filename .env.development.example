# Copy to `.env` on the machine that runs Compose (TrueNAS, laptop, etc.).
# File `.env` is gitignored — put real tokens only there, never commit them.
#
#   cp .env.development.example .env
#   nano .env

# --- Discord (developer portal) ---
DISCORD_TOKEN=paste_bot_token_here
DISCORD_CLIENT_ID=paste_application_id_here
DISCORD_GUILD_ID=paste_server_id_here

# Comma-separated channel IDs (no spaces)
TRACKED_CHANNELS=paste_channel_id_1,paste_channel_id_2
SUMMARY_CHANNEL_ID=paste_summary_channel_id_here

# Cron + timezone (IANA). Example: weekdays 18:00 in New York
SUMMARY_CRON=0 18 * * 1-5
TZ=America/New_York

# Inside Compose, the bot reaches Ollama by service name — leave this alone.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# SQLite inside the bot volume
DB_PATH=/data/bot.db
